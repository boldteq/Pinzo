{% comment %}
  Pinzo — Cart Validator Block
  Place this block on your Cart page template in the Theme Editor.
  It reads the validation state set by the Pinzo widget and
  warns customers with non-serviceable ZIP codes before they check out.
{% endcomment %}

{% if request.design_mode %}
  {%- comment -%} Theme Editor preview — show sample warning state {%- endcomment -%}
  <div class="zcc-cart-warning zcc-cart-warning--preview" style="
    background: #fff4f4;
    border: 2px solid #d72c0d;
    border-radius: 8px;
    padding: 16px 20px;
    margin: 16px 0;
    font-family: inherit;
  ">
    <div style="display:flex; align-items:center; gap:10px;">
      <span style="font-size:1.4em;">⚠️</span>
      <div>
        <strong style="color:#d72c0d; font-size:0.95em;">Delivery Not Available</strong>
        <p style="margin:4px 0 0; font-size:0.85em; color:#6d7175;">
          The Pinzo Cart Validator is active. Customers with non-serviceable ZIP codes will see a warning here.
        </p>
      </div>
    </div>
  </div>
{% else %}
  {%- liquid
    assign shop_domain = shop.permanent_domain
    assign metafield_value = app.metafields.zip_checker.widget_config.value
  -%}

  <div
    id="zcc-cart-validator"
    data-api="{{ app.url }}"
    data-proxy="/apps/zipcheck"
    style="display:none; margin: 16px 0;"
    aria-live="polite"
  ></div>

  <style>
    #zcc-cart-validator { font-family: inherit; }
    .zcc-cv-banner {
      background: #fff4f4;
      border: 2px solid #d72c0d;
      border-radius: 8px;
      padding: 16px 20px;
      display: flex;
      align-items: flex-start;
      gap: 12px;
    }
    .zcc-cv-icon { font-size: 1.3em; flex-shrink: 0; margin-top: 2px; }
    .zcc-cv-content { flex: 1; }
    .zcc-cv-title {
      color: #d72c0d;
      font-weight: 700;
      font-size: 0.95em;
      margin: 0 0 4px;
    }
    .zcc-cv-msg {
      color: #202223;
      font-size: 0.875em;
      margin: 0 0 8px;
    }
    .zcc-cv-zip {
      font-weight: 700;
      color: #d72c0d;
    }
    .zcc-cv-actions { display: flex; gap: 10px; flex-wrap: wrap; margin-top: 4px; }
    .zcc-cv-dismiss {
      background: none;
      border: 1px solid #d72c0d;
      color: #d72c0d;
      border-radius: 4px;
      padding: 4px 12px;
      font-size: 0.8em;
      cursor: pointer;
    }
    .zcc-cv-dismiss:hover { background: #d72c0d; color: #fff; }
    .zcc-checkout-blocked { opacity: 0.4 !important; pointer-events: none !important; cursor: not-allowed !important; }
    .zcc-checkout-notice {
      font-size: 0.78em;
      color: #d72c0d;
      margin-top: 6px;
      text-align: center;
      display: none;
    }
  </style>

  <script>
  (function() {
    var SHOP = {{ shop_domain | json }};
    var META_RAW = {{ metafield_value | default: 'null' | json }};

    // Resolve API base the same way the main widget does: prefer the full
    // app URL from Shopify Liquid (`app.url`), fall back to the App Proxy
    // path so requests still route through Shopify when rendered outside a
    // context where `app.url` is populated.
    var _container = document.getElementById('zcc-cart-validator');
    var _rawApi = (_container && _container.dataset.api || '').replace(/\/$/, '');
    var _proxyPath = (_container && _container.dataset.proxy || '/apps/zipcheck').replace(/\/$/, '');
    var API_BASE = (_rawApi && _rawApi.indexOf('http') === 0) ? _rawApi : _proxyPath;

    function escapeHtml(str) {
      var d = document.createElement('div');
      d.textContent = str;
      return d.innerHTML;
    }

    // Escape untrusted content used inside HTML attribute values.
    function escapeAttr(str) {
      return String(str == null ? '' : str)
        .replace(/&/g, '&amp;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;');
    }

    var cfg = { blockCheckoutInCart: false };
    try {
      var meta = META_RAW ? JSON.parse(META_RAW) : null;
      if (meta) cfg = Object.assign(cfg, meta);
    } catch(e) {}

    var CHECKOUT_SELECTORS = [
      '[name="checkout"]',
      '.cart__checkout-button',
      '.cart-checkout-btn',
      'button[data-action="checkout"]',
      '.checkout-button',
      'input[name="checkout"]',
      '[href="/checkout"]',
      'a.btn[href*="checkout"]'
    ];

    function blockCheckout(zip) {
      CHECKOUT_SELECTORS.forEach(function(sel) {
        try {
          document.querySelectorAll(sel).forEach(function(el) {
            el.classList.add('zcc-checkout-blocked');
            el.setAttribute('data-zcc-checkout-blocked', 'true');
            el.setAttribute('title', 'Delivery is not available for ZIP code ' + zip + '. Please update your ZIP code.');
          });
        } catch(e) {}
      });
    }

    function unblockCheckout() {
      document.querySelectorAll('[data-zcc-checkout-blocked="true"]').forEach(function(el) {
        el.classList.remove('zcc-checkout-blocked');
        el.removeAttribute('data-zcc-checkout-blocked');
        el.removeAttribute('title');
      });
    }

    function renderBlocked(zip) {
      var wrapper = document.getElementById('zcc-cart-validator');
      if (!wrapper) return;
      wrapper.style.display = 'block';
      wrapper.innerHTML = '<div class="zcc-cv-banner">'
        + '<span class="zcc-cv-icon">⚠️</span>'
        + '<div class="zcc-cv-content">'
        + '<p class="zcc-cv-title">Delivery Not Available for Your Area</p>'
        + '<p class="zcc-cv-msg">Your ZIP code <span class="zcc-cv-zip">' + escapeHtml(zip) + '</span> is outside our current delivery area. Please remove restricted items or check a different ZIP code.</p>'
        + '<div class="zcc-cv-actions">'
        + '<button class="zcc-cv-dismiss" type="button" data-zcc-dismiss="1">Dismiss</button>'
        + '</div>'
        + '</div>'
        + '</div>';
      var dismiss = wrapper.querySelector('[data-zcc-dismiss="1"]');
      if (dismiss) dismiss.addEventListener('click', function() { wrapper.style.display = 'none'; });

      if (cfg.blockCheckoutInCart) {
        blockCheckout(escapeAttr(zip));
        var notice = document.createElement('p');
        notice.className = 'zcc-checkout-notice';
        notice.style.display = 'block';
        notice.textContent = 'Checkout unavailable — ZIP code ' + zip + ' is not in our delivery area.';
        wrapper.appendChild(notice);
      }
    }

    function renderHidden() {
      var wrapper = document.getElementById('zcc-cart-validator');
      if (wrapper) wrapper.style.display = 'none';
      unblockCheckout();
    }

    // Re-verify with the server rather than trusting sessionStorage.
    // This closes the bypass where a customer could write
    //   sessionStorage.setItem('zcc:valid', 'true')
    // in the browser console to unlock checkout. The cart-validator now
    // asks the API every time and only trusts its live response.
    function verifyAndRender(zip) {
      var timeout = new AbortController();
      var timeoutId = setTimeout(function() { timeout.abort(); }, 5000);
      fetch(API_BASE + '/api/zip-check?shop=' + encodeURIComponent(SHOP) + '&zip=' + encodeURIComponent(zip), {
        method: 'GET',
        signal: timeout.signal,
        headers: { 'Accept': 'application/json' }
      })
        .then(function(r) { return r.json(); })
        .then(function(data) {
          if (!data || data.allowed === true) {
            renderHidden();
          } else {
            renderBlocked(zip);
          }
        })
        .catch(function() {
          // Network or timeout error — fail closed only if merchant opted in.
          if (cfg.blockCheckoutInCart) renderBlocked(zip);
        })
        .finally(function() { clearTimeout(timeoutId); });
    }

    function init() {
      var wrapper = document.getElementById('zcc-cart-validator');
      if (!wrapper) return;

      var zip, storedShop;
      try {
        zip = sessionStorage.getItem('zcc:zip');
        storedShop = sessionStorage.getItem('zcc:shop');
      } catch(e) { return; }

      // Only act if the stored ZIP is for THIS shop and present.
      if (!zip || storedShop !== SHOP) return;

      verifyAndRender(zip);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }

    // Listen for zcc:validated events fired by the widget so the cart reacts
    // immediately when the customer re-checks their ZIP on the same page.
    window.addEventListener('zcc:validated', function(e) {
      try {
        var detail = e.detail;
        if (detail && detail.zip) {
          sessionStorage.setItem('zcc:zip', detail.zip);
          sessionStorage.setItem('zcc:shop', SHOP);
          verifyAndRender(detail.zip);
        }
      } catch(e) {}
    });
  })();
  </script>
{% endif %}

{% schema %}
{
  "name": "Cart Validator",
  "target": "section",
  "settings": []
}
{% endschema %}
