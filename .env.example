# Shopify App (required — set by Shopify CLI during `shopify app dev`)
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_APP_URL=https://your-app.up.railway.app
SCOPES=read_themes

# Database (required)
DATABASE_URL=postgresql://user:password@localhost:5432/pinzo

# Email — Resend (required for waitlist emails)
RESEND_API_KEY=re_xxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@yourdomain.com

# Optional
SHOP_CUSTOM_DOMAIN=           # Custom myshopify.com domain alias
ADMIN_SHOP=                   # Shop domain with admin privileges (e.g. your-store.myshopify.com)
CHATWOOT_WEBSITE_TOKEN=       # Chatwoot live-chat widget token
CLAUDE_HUB_URL=               # Agent SDK endpoint (dev only, default: http://localhost:3847)
